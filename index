<script>
// ─── MODE SWITCHING ───
let currentMode = 'clinical';
let currentClinicalTab = 'overview';
let currentPatientTab = 'p-what';

function setMode(mode) {
  currentMode = mode;
  document.body.className = mode === 'patient' ? 'mode-patient' : '';
  
  document.getElementById('btn-clinical').className = 'toggle-btn' + (mode === 'clinical' ? ' active' : '');
  document.getElementById('btn-patient').className = 'toggle-btn' + (mode === 'patient' ? ' active' : '');
  
  document.getElementById('tabs-clinical').style.display = mode === 'clinical' ? 'contents' : 'none';
  document.getElementById('tabs-patient').style.display = mode === 'patient' ? 'contents' : 'none';
  document.getElementById('hero-clinical').style.display = mode === 'clinical' ? 'block' : 'none';
  document.getElementById('hero-patient').style.display = mode === 'patient' ? 'block' : 'none';
  
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  
  const activeTab = mode === 'clinical' ? currentClinicalTab : currentPatientTab;
  showTab(activeTab, true);
}

// ─── TAB SWITCHING ───
function showTab(id, fromMode) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  
  const sec = document.getElementById('sec-' + id);
  if(sec) sec.classList.add('active');
  
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  
  const tabs = currentMode === 'clinical' 
    ? document.getElementById('tabs-clinical')
    : document.getElementById('tabs-patient');
  
  if(tabs) {
    const btns = tabs.querySelectorAll('.tab-btn');
    btns.forEach(b => {
      if(b.getAttribute('onclick') && b.getAttribute('onclick').includes("'"+id+"'")) {
        b.classList.add('active');
      }
    });
  }
  
  if(!fromMode) {
    if(currentMode === 'clinical') currentClinicalTab = id;
    else currentPatientTab = id;
  }
  
  window.scrollTo({ top: document.querySelector('.nav-tabs').offsetTop - 70, behavior: 'smooth' });
}

// ─── ALOSTATIC LOAD CALC ───
function calcAlost(el) {
  el.classList.toggle('selected');
  const checks = el.querySelectorAll ? el : document.querySelectorAll ? null : null;
  const chips = document.getElementById('alost-checks').querySelectorAll('.symptom-chip');
  let score = 0;
  chips.forEach(c => { if(c.classList.contains('selected')) score += 2; });
  
  const resultBox = document.getElementById('alost-result');
  const scoreEl = document.getElementById('alost-score');
  const fillEl = document.getElementById('alost-fill');
  const textEl = document.getElementById('alost-text');
  const actionsEl = document.getElementById('alost-actions');
  
  resultBox.classList.add('show');
  scoreEl.textContent = score;
  fillEl.style.width = Math.min(score * 8, 100) + '%';
  
  const messages = {
    low: 'Carga alostática baja. Protocolo completo aplicable. Escalar progresivamente.',
    mid: 'Carga moderada. Aplicar 50% del protocolo, escalar gradual. Priorizar SNA.',
    high: 'Carga alta. Priorizar SNA + tiroides + erradicar H. pylori ANTES de cualquier ácido exógeno.',
    critical: 'Carga muy alta. NO suplementar ácido. Trabajo de regulación autonómica primero. Evaluación completa necesaria.'
  };
  
  const actions = {
    low: ['<span class="tag-action">Protocolo completo</span>'],
    mid: ['<span class="tag-action">50% del protocolo</span>', '<span class="tag-action">Escalar semanal</span>'],
    high: ['<span class="tag-action">SNA primero</span>', '<span class="tag-action">Tiroides</span>', '<span class="tag-action">Erradicar H. pylori</span>'],
    critical: ['<span class="tag-action" style="color:var(--danger);border-color:rgba(255,77,109,0.3);background:rgba(255,77,109,0.1)">NO HCl exógeno</span>', '<span class="tag-action">Regulación autonómica</span>']
  };
  
  const key = score <= 3 ? 'low' : score <= 6 ? 'mid' : score <= 10 ? 'high' : 'critical';
  textEl.textContent = messages[key];
  actionsEl.innerHTML = actions[key].join('');
}

// ─── SCENARIO SWITCHER ───
function showScenario(id) {
  ['a','b1','b2','b3','b4'].forEach(s => {
    document.getElementById('sc-content-' + s).style.display = 'none';
    document.getElementById('sc-' + s).className = 'pill';
  });
  document.getElementById('sc-content-' + id).style.display = 'block';
  document.getElementById('sc-' + id).className = 'pill blue';
}

// ─── CASE SWITCHER ───
function showCase(n) {
  [1,2,3].forEach(i => {
    document.getElementById('case-' + i).style.display = 'none';
    document.getElementById('cn-' + i).className = 'pill';
  });
  document.getElementById('case-' + n).style.display = 'block';
  document.getElementById('cn-' + n).className = 'pill blue';
}

