function toggleSymptom(el, id) {
  el.classList.toggle('selected');
  if(selectedSymptoms.has(id)) selectedSymptoms.delete(id);
  else selectedSymptoms.add(id);
  updateSymptomResult();
}

function updateSymptomResult() {
  const n = selectedSymptoms.size;
  const result = document.getElementById('p-symptom-result');
  const score = document.getElementById('p-sym-score');
  const text = document.getElementById('p-sym-text');
  const actions = document.getElementById('p-sym-actions');
  
  result.classList.add('show');
  score.textContent = n + '/15';
  
  if(n === 0) { text.textContent = 'Selecciona los síntomas que reconoces.'; actions.innerHTML = ''; return; }
  
  const hasDigestive = selectedSymptoms.has('1') || selectedSymptoms.has('2') || selectedSymptoms.has('3');
  const hasNutritional = selectedSymptoms.has('9') || selectedSymptoms.has('10') || selectedSymptoms.has('11');
  const hasReflux = selectedSymptoms.has('4');
  const hasNeuro = selectedSymptoms.has('11') || selectedSymptoms.has('14');
  
  let msg = '';
  let acts = [];
  
  if(n <= 3) { msg = 'Tienes algunos síntomas que pueden estar relacionados con digestión baja. Empezar con cambios de hábitos es un excelente primer paso.'; }
  else if(n <= 7) { msg = 'Varios síntomas apuntan a que tu estómago no está produciendo suficiente ácido. Habla con tu especialista para confirmar y iniciar un plan.'; acts = ['Hablar con tu nutrióloga','Análisis de sangre básico','Cambios de hábitos inmediatos']; }
  else { msg = 'Tu perfil de síntomas es muy sugestivo de hipoclorhidria. Es importante que tu especialista evalúe esto con laboratorios específicos y un plan personalizado.'; acts = ['Evaluación completa urgente','Laboratorios funcionales','Plan personalizado']; }
  
  if(hasNutritional) acts.push('Revisar B12, hierro, zinc');
  if(hasReflux) acts.push('El reflujo puede ser por POCO ácido');
  if(hasNeuro) acts.push('Revisar B12 funcional (MMA)');
  
  text.textContent = msg;
  actions.innerHTML = acts.map(a => `<span class="tag-action">${a}</span>`).join('');
}
</script>
